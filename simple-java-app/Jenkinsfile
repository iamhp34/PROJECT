pipeline {
    agent any

    parameters {
        string(name: 'GIT_BRANCH',      defaultValue: 'main',
               description: 'Source code branch')
        string(name: 'GIT_REPO_URL',    defaultValue: 'https://github.com',
               description: 'App source repo')
        string(name: 'APP_DIRECTORY',   defaultValue: 'simple-java-app',
               description: 'Java app folder')

        string(name: 'SONAR_IP_PORT',   defaultValue: '13.233.106.75:30665',
               description: 'SonarQube IP and Port without http://')

        string(name: 'NEXUS_IP_PORT',   defaultValue: '13.233.9.11:30001',
               description: 'Nexus IP and Port without http://')
        string(name: 'NEXUS_REPOSITORY',defaultValue: 'maven-releases',
               description: 'Nexus hosted repository name')
        string(name: 'MAVEN_GROUP_ID',  defaultValue: 'com/example',
               description: 'Maven group path')

        string(name: 'MANIFESTS_REPO',  defaultValue: 'https://github.com',
               description: 'K8s manifests repo URL')
    }

    tools {
        jdk    'jdk17'
        maven  'maven3'
    }

    environment {
        SONAR_SERVER_ENV = 'sonar-server'
        NEXUS_CREDS_ID   = 'nexus-creds'
        GITHUB_CREDS     = 'github-creds'

        AWS_REGION   = 'ap-south-1'
        ECR_REGISTRY = '://amazonaws.com'
        ECR_REPO     = 'hariprasad-app'

        IMAGE_TAG    = "${BUILD_NUMBER}"
        FULL_IMAGE   = "://amazonaws.com/hariprasad-app:${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo "Stage 1: Fetching source from branch: ${params.GIT_BRANCH}..."
                git branch: "${params.GIT_BRANCH}",
                    url:    "${params.GIT_REPO_URL}"
            }
        }

        stage('Build JAR') {
            steps {
                dir("${params.APP_DIRECTORY}") {
                    echo "Stage 2: Building JAR..."
                    sh 'mvn clean package -DskipTests'
                    sh "ls -lh target/*.jar"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${params.APP_DIRECTORY}") {
                    echo "Stage 3: Running SonarQube analysis..."
                    withSonarQubeEnv("${env.SONAR_SERVER_ENV}") {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.host.url=http://${params.SONAR_IP_PORT}
                        """
                    }
                }
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Push to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${env.NEXUS_CREDS_ID}",
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    script {
                        echo "Stage 4: Uploading JAR to Nexus..."
                        def localJarPath = sh(
                            script: "ls ${params.APP_DIRECTORY}/target/*.jar | grep -v original",
                            returnStdout: true
                        ).trim()
                        def artifactName    = "${JOB_NAME}"
                        def artifactVersion = "${BUILD_NUMBER}"
                        sh """
                            curl -f \
                                -u \$NEXUS_USER:\$NEXUS_PASS \
                                --upload-file ${localJarPath} \
                                "http://${params.NEXUS_IP_PORT}/repository/${params.NEXUS_REPOSITORY}/${params.MAVEN_GROUP_ID}/${artifactName}/${artifactVersion}/${artifactName}-${artifactVersion}.jar"
                        """
                        echo " JAR pushed → Nexus build ${artifactVersion}"
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${params.APP_DIRECTORY}") {
                    echo "Stage 5: Building Docker image..."
                    script {
                        // Safely resolve your UI tool path via Groovy variables instead of withEnv macros
                        def dockerToolHome = tool name: 'latest', type: 'org.jenkinsci.plugins.docker.commons.tools.DockerTool'
                        sh """
                            export PATH="\$PATH:${dockerToolHome}/bin"
                            
                            docker build \
                                --build-arg BUILD_NUMBER=${env.BUILD_NUMBER} \
                                -t ${env.FULL_IMAGE} \
                                -t ${env.ECR_REGISTRY}/${env.ECR_REPO}:latest \
                                .
                        """
                    }
                }
                echo " Image built: ${env.FULL_IMAGE}"
            }
        }

        stage('Push to ECR') {
            steps {
                echo "Stage 6: Pushing image to ECR..."
                script {
                    def dockerToolHome = tool name: 'latest', type: 'org.jenkinsci.plugins.docker.commons.tools.DockerTool'
                    sh """
                        export PATH="\$PATH:${dockerToolHome}/bin"

                        aws ecr get-login-password --region ${env.AWS_REGION} | \
                            docker login \
                                --username AWS \
                                --password-stdin ${env.ECR_REGISTRY}

                        docker push ${env.FULL_IMAGE}
                        docker push ${env.ECR_REGISTRY}/${env.ECR_REPO}:latest

                        docker rmi ${env.FULL_IMAGE} || true
                        docker rmi ${env.ECR_REGISTRY}/${env.ECR_REPO}:latest || true
                    """
                }
                echo " Pushed to ECR: ${env.FULL_IMAGE}"
            }
        }

        stage('Update Helm Values') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${env.GITHUB_CREDS}",
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh """
                        rm -rf hariprasad-k8s-manifests
                        git clone https://\$GIT_USER:\$GIT_TOKEN@://github.com
                        cd hariprasad-k8s-manifests

                        sed -i 's|tag:.*|tag: "${BUILD_NUMBER}"|' hariprasad-chart/values.yaml

                        echo "Updated values.yaml:"
                        cat hariprasad-chart/values.yaml

                        git config user.email "jenkins@ci.com"
                        git config user.name "Jenkins CI"
                        git add hariprasad-chart/values.yaml
                        git commit -m "ci: update image tag to build-${BUILD_NUMBER}"
                        git push origin main
                    """
                }
                echo " Helm values updated → ArgoCD deploying build ${BUILD_NUMBER}"
            }
        }
    }

    post {
        success {
            echo """
            ╔══════════════════════════════════════════════════╗
            ║  CI PIPELINE SUCCEEDED                        
            ║  Build    : ${BUILD_NUMBER}                      ║
            ║  JAR      : Nexus build-${BUILD_NUMBER}          ║
            ║  Image    : ${env.FULL_IMAGE}                    ║
            ║  ArgoCD   : deploying automatically              ║
            ╚══════════════════════════════════════════════════╝
            """
        }
        failure {
            echo ' Pipeline FAILED — check stage logs above'
        }
        always {
            cleanWs()
        }
    }
}
